{
  "name": "uk-account-check",
  "version": "1.3.0-v880.0",
  "description": "Uses the Vocalink Modulus Checking system to verify UK bank account details",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown --minify",
    "changeset": "changeset",
    "convert-data": "node scripts/convert-data.js",
    "dev": "tsdown --watch",
    "lint": "biome check --write src",
    "lint:ci": "biome check",
    "release": "pnpm build && changeset publish",
    "test:watch": "vitest",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "version": "changeset version"
  },
  "keywords": [
    "modulus",
    "bank",
    "account",
    "vocalink"
  ],
  "author": "Glenn Sayers",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/glennsayers/uk-account-check"
  },
  "bugs": {
    "url": "https://github.com/glennsayers/uk-account-check/issues"
  },
  "homepage": "https://github.com/glennsayers/uk-account-check#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.6.0",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
